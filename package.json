{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "@imsus/laravel-inertia-vue-starter-kit",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vue-tsc && vp build",
    "build:ssr": "vue-tsc && vp build && vp build --ssr",
    "dev": "vp dev",
    "format": "vp fmt",
    "lint": "vp lint",
    "check": "vp check"
  },
  "dependencies": {
    "@inertiajs/vite": "3.0.0-beta.1",
    "@inertiajs/vue3": "3.0.0-beta.3",
    "@vueuse/core": "^14.2.1",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.98",
    "@iconify-json/ph": "^1.2.2",
    "@laravel/vite-plugin-wayfinder": "^0.1.7",
    "@tailwindcss/vite": "0.0.0-insiders.bb2f170",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "concurrently": "^9.2.1",
    "laravel-vite-plugin": "^2.1.0",
    "tailwindcss": "0.0.0-insiders.bb2f170",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^31.0.0",
    "vite-plus": "latest",
    "vue-tsc": "^3.2.6"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.9.5",
    "@tailwindcss/oxide-linux-x64-gnu": "^4.2.1",
    "lightningcss-linux-x64-gnu": "^1.32.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
